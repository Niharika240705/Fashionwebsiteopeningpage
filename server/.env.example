PORT=5001
NODE_ENV=development

# MongoDB — local dev default; use Atlas URI in production
MONGODB_URI=mongodb://localhost:27017/fashion-website

JWT_SECRET=change-me-access-secret-min-32-chars-long
REFRESH_TOKEN_SECRET=change-me-refresh-secret-min-32-chars
SESSION_SECRET=change-me-session-secret-min-32-chars-long
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=
BACKEND_URL=http://localhost:5001

# --- Google OAuth (Sign in with Google) ---
# Leave both blank to run with email/password only — the "Continue with Google" button
# will auto-disable itself (GET /api/auth/providers) instead of erroring out.
# To enable: Google Cloud Console -> APIs & Services -> Credentials -> Create Credentials ->
# OAuth client ID -> Application type "Web application". Then set:
#   Authorized JavaScript origins: http://localhost:3000
#   Authorized redirect URIs:      http://localhost:5001/api/auth/google/callback
# Paste the generated Client ID / Client Secret below. See AUTHENTICATION_SETUP.md for full steps.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5001/api/auth/google/callback
ADMIN_EMAILS=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=processed-images

# --- Python fashion-ingestion bridge (Zara/H&M/etc. via FastAPI) ---
# When true, GET /api/products* proxies to PYTHON_INGESTION_API_URL and maps responses.
USE_PYTHON_CATALOG=false
PYTHON_INGESTION_API_URL=http://localhost:8000

# --- Catalog ingestion (recommended local/dev path) ---
# Seed partner catalog manually: npm run ingest:demo
# One-time sync Python -> Mongo (works when Python is down): npm run sync:python
AUTO_INGEST_DEMO=false
ENABLE_DEMO_FEED=true
DEMO_AFFILIATE_FEED_URL=

# Live retailer scraping — keep false unless you run permitted Playwright workers
ENABLE_MYNTRA_SCRAPE=false
ENABLE_HM_SCRAPE=false
ENABLE_ZARA_SCRAPE=false
ENABLE_SCHEDULED_SCRAPING=false
SCRAPER_DEBUG=false
MYNTRA_WOMEN_LISTING_URL=https://www.myntra.com/women-dresses
NEUTRAL_PRODUCT_PLACEHOLDER_URL=https://via.placeholder.com/600x800?text=Product+Image+Unavailable

# Render cron calls POST /api/admin/ingestion/ingest/demo-affiliate with x-cron-token
CRON_INGEST_SOURCE=demo-affiliate
CRON_ADMIN_TOKEN=

# --- Virtual Try-On (POST /api/try-on) ---
# Photorealistic generative try-on (IDM-VTON family). Configure ONE provider below.
# Leave both blank and set TRY_ON_MOCK=true to test the UI locally without a key —
# mock mode returns a clearly labeled "Demo mode" composite, never claimed as photorealistic.
TRY_ON_PROVIDER=replicate
# Replicate (recommended): https://replicate.com/cuuupid/idm-vton
REPLICATE_API_TOKEN=
REPLICATE_VTON_MODEL_VERSION=906425dbca90663ff5427624839572cc56ea7d380343d13e2a4c4b09d3f0c30f
# fal.ai (alternative): https://fal.ai/models/fal-ai/idm-vton
FAL_KEY=
FAL_VTON_MODEL=fal-ai/idm-vton
# Local/dev only — never enable in production.
TRY_ON_MOCK=false

# --- Persona AI assistant (POST /api/assistant/chat) ---
# Optional. Leave blank to run on rules + catalog search only (no LLM cost,
# still fully functional for try-on/budget/wedding/FAQ questions and product
# search). Set a key to let Persona AI answer open-ended fashion questions
# via OpenAI, using a server-side system prompt (never exposed to the client).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
